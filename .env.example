# WEEZLY Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development

# SMTP Email Configuration (for sending real emails)
# See README.md for detailed guide on setting up App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-digit-app-password
SMTP_FROM=WEEZLY Platform <noreply@weezly.com>

# Stripe Payment Gateway Configuration
# See README.md for guide on getting test credentials from Stripe dashboard
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# API URL (for frontend to connect to backend)
VITE_API_URL=http://localhost:3001/api
